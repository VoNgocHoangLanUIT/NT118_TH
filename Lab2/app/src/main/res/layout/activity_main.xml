<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENU LAB 02"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnBai1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trường hợp 1 (Mảng tĩnh)"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnBai3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trường hợp 3 (ArrayList)"/>

    <Button
        android:id="@+id/btnBai4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trường hợp 4 (Object)"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnBai5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trường hợp 5 (Custom Adapter)"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnBai6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trường hợp 6 (GridView - Spinner)"/>
</LinearLayout>